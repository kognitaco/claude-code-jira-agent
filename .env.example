# Shared secret Jira will send in the X-Jira-Authentication header.
# Generate with: openssl rand -hex 32
JIRA_WEBHOOK_SECRET=replace-me

# URL of the containerized Claude Code service (https://github.com/kognitaco/containerized-claude-code).
CLAUDE_AGENT_URL=http://claude-code:80
CLAUDE_TIMEOUT_SECONDS=600

# Jira REST credentials for posting comments back on the issue.
JIRA_BASE_URL=https://your-tenant.atlassian.net
JIRA_EMAIL=bot@your-org.com
JIRA_API_TOKEN=replace-me
